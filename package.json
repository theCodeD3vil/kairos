{
  "name": "kairos",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.9.0",
  "workspaces": [
    "apps/*",
    "apps/desktop/frontend",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "pnpm --filter @kairos/desktop-frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
