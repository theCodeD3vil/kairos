{
  "name": "kairos-vscode",
  "displayName": "Kairos",
  "version": "1.1.10",
  "publisher": "kairos-dev",
  "description": "Local-first activity tracking for Kairos Desktop from inside VS Code.",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": ["Other", "Productivity"],
  "keywords": [
    "kairos",
    "desktop",
    "productivity",
    "activity-tracking",
    "local-first",
    "time-awareness"
  ],
  "icon": "media/kairos-logo.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "homepage": "https://github.com/michaelnji/kairos/tree/main/apps/vscode-extension",
  "bugs": {
    "url": "https://github.com/michaelnji/kairos/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelnji/kairos.git",
    "directory": "apps/vscode-extension"
  },
  "main": "./dist/extension.js",
  "extensionKind": ["workspace"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:kairos.refreshSettings",
    "onCommand:kairos.reconnectDesktop",
    "onCommand:kairos.openDesktop",
    "onCommand:kairos.showStatus",
    "onCommand:kairos.showOutput",
    "onCommand:kairos.statusAction"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kairos.refreshSettings",
        "title": "Refresh Desktop Settings",
        "category": "Kairos"
      },
      {
        "command": "kairos.reconnectDesktop",
        "title": "Reconnect to Kairos Desktop",
        "category": "Kairos"
      },
      {
        "command": "kairos.openDesktop",
        "title": "Open Kairos Desktop",
        "category": "Kairos"
      },
      {
        "command": "kairos.showStatus",
        "title": "Show Kairos Status",
        "category": "Kairos"
      },
      {
        "command": "kairos.showOutput",
        "title": "Show Kairos Output",
        "category": "Kairos"
      },
      {
        "command": "kairos.statusAction",
        "title": "Open Kairos Actions",
        "category": "Kairos"
      }
    ]
  },
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "pretypecheck": "pnpm --filter @kairos/shared build",
    "pretest": "pnpm --filter @kairos/shared build",
    "build": "pnpm run build:release",
    "build:dev": "pnpm --filter @kairos/shared build && node esbuild.mjs",
    "build:release": "pnpm run clean && pnpm --filter @kairos/shared build && node esbuild.mjs --release",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node ./scripts/run-compiled-tests.mjs",
    "package:vsix": "pnpm run build:release && vsce package --no-dependencies --out dist/kairos-vscode-${npm_package_version}.vsix",
    "publish:marketplace": "vsce publish --packagePath dist/kairos-vscode-${npm_package_version}.vsix",
    "verify:release": "pnpm run typecheck && pnpm run test && pnpm run build:release",
    "lint": "echo \"No lint rules configured yet for kairos-vscode\""
  },
  "dependencies": {
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@kairos/shared": "workspace:*",
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.98.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
