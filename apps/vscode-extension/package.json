{
  "name": "kairos-vscode",
  "displayName": "Kairos VS Code",
  "version": "0.0.0",
  "private": true,
  "description": "Kairos VS Code extension scaffold",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onCommand:kairos.hello"],
  "contributes": {
    "commands": [
      {
        "command": "kairos.hello",
        "title": "Kairos: Hello"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint rules configured yet for kairos-vscode\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.98.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
